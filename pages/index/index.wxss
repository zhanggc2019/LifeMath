.container {
  padding: 32rpx;
  min-height: 100vh;
  background: linear-gradient(180deg, #ff6b6b 0%, #ff9f43 200rpx);
  padding-bottom: 140rpx;
}

.header {
  text-align: center;
  padding: 40rpx 0 60rpx;
}

.title {
  display: block;
  font-size: 48rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 16rpx;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.85);
}

.card {
  display: flex;
  align-items: center;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 36rpx 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.card-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.tax-icon {
  background: linear-gradient(135deg, #ff6b6b 0%, #ff9f43 100%);
}

.loan-icon {
  background: linear-gradient(135deg, #ff9f43 0%, #ffb347 100%);
}

.health-icon {
  background: linear-gradient(135deg, #07c160 0%, #10b981 100%);
}

.converter-icon {
  background: linear-gradient(135deg, #ff7a59 0%, #ffb347 100%);
}

.icon-text {
  font-size: 40rpx;
  font-weight: 700;
  color: #ffffff;
}

.card-content {
  flex: 1;
}

.card-title {
  display: block;
  font-size: 34rpx;
  font-weight: 600;
  color: #323233;
  margin-bottom: 6rpx;
}

.card-desc {
  display: block;
  font-size: 24rpx;
  color: #969799;
  line-height: 1.4;
}

.arrow-icon {
  font-size: 48rpx;
  color: #dcdee0;
  font-weight: 300;
}

/* 自定义底部导航 */
.custom-tabbar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  justify-content: space-around;
  align-items: center;
  height: 110rpx;
  background: #ffffff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 100;
}

.tabbar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: 1;
  height: 100%;
}

.tabbar-item.active .tabbar-text {
  color: #ff6b6b;
}

.tabbar-icon {
  font-size: 40rpx;
  margin-bottom: 4rpx;
}

.tabbar-text {
  font-size: 22rpx;
  color: #969799;
}

.tabbar-item.active .tabbar-text {
  color: #ff6b6b;
  font-weight: 600;
}
