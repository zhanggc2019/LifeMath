.container {
  padding: 24rpx;
  min-height: 100vh;
  background: #f7f8fa;
}

.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #323233;
  margin-bottom: 20rpx;
}

.category-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.category-item {
  width: calc((100% - 36rpx) / 4);
  height: 72rpx;
  border-radius: 14rpx;
  border: 1rpx solid #ebedf0;
  background: #ffffff;
  color: #323233;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.category-item.active {
  border: none;
  background: linear-gradient(135deg, #ff6b6b 0%, #ff9f43 100%);
  color: #ffffff;
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 107, 0.24);
}

.reset-item {
  color: #ff6b6b;
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.reset-icon {
  font-size: 30rpx;
}

.converter-card {
  padding: 32rpx;
}

.field-label {
  display: block;
  font-size: 44rpx;
  color: #323233;
  margin-bottom: 14rpx;
}

.value-input,
.value-output {
  background: #f7f8fa;
  border-radius: 14rpx;
  padding: 20rpx 24rpx;
  font-size: 52rpx;
  font-weight: 600;
  color: #323233;
  margin-bottom: 18rpx;
}

.value-output {
  color: #ff6b6b;
  min-height: 74rpx;
}

.picker-field {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #f7f8fa;
  border-radius: 14rpx;
  padding: 18rpx 24rpx;
  font-size: 34rpx;
  color: #323233;
}

.arrow {
  font-size: 22rpx;
  color: #969799;
}

.swap-wrap {
  width: 92rpx;
  height: 92rpx;
  margin: 24rpx auto;
  border-radius: 46rpx;
  background: #fff5f5;
  display: flex;
  align-items: center;
  justify-content: center;
}

.swap-icon {
  font-size: 52rpx;
  color: #ff6b6b;
}

.formula-card {
  background: linear-gradient(180deg, #fff5f5 0%, #ffffff 100rpx);
}

.formula-title {
  display: block;
  font-size: 34rpx;
  font-weight: 600;
  color: #323233;
  margin-bottom: 16rpx;
}

.formula-text {
  display: block;
  font-size: 30rpx;
  color: #646566;
  line-height: 1.5;
}
